  "type": "module",
  "exports": {
    "./client": {
      "types": "./src/client.ts",
      "module": "./src/client.ts"
    },
    "./server": {
      "types": "./src/server.ts",
      "module": "./src/server.ts"
    }
  },
  "scripts": {
    "build": "bun src/scripts/build.ts",
    "build:d1-sql": "bun src/scripts/build-d1-sql.ts",
    "build:db": "bun src/scripts/build-db/build-db.ts",
    "dev": "bun --watch src/index.ts",
    "setup": "bun src/scripts/setup/setup.ts",
    "test": "bun test"
  },
  "dependencies": {
    "@hono/zod-openapi": "1.2.2",
    "@hono/zod-validator": "0.7.6",
    "@scalar/hono-api-reference": "0.10.2",
    "drizzle-orm": "0.45.1",
    "drizzle-zod": "0.8.3",
    "goodcodes-parser": "2.5.0",
    "hono": "4.12.7",
    "json5": "2.2.3",
    "nanoid": "5.1.6",
    "nanoid-dictionary": "5.0.0"
  },
  "devDependencies": {
    "@tsconfig/bun": "1.0.10",
    "@types/bun": "1.3.10",
    "@types/fs-extra": "11.0.4",
    "@types/node": "25.4.0",
    "@types/pug": "2.0.10",
    "@types/sax": "1.2.7",
    "drizzle-kit": "0.31.9",
    "es-toolkit": "1.45.1",
    "esbuild": "0.27.3",
    "execa": "9.6.1",
    "fs-extra": "11.3.4",
    "jiti": "2.6.1",
    "libretrodb": "1.0.0",
    "sax": "1.5.0",
    "simple-git-hooks": "2.13.1",
    "wrangler": "4.72.0"
  },
  "simple-git-hooks": {
    "pre-commit": "bun oxfmt && bun oxlint"
  },
  "engines": {
    "bun": ">=1.3.5"
  },
  "packageManager": "bun@1.3.10"
}
